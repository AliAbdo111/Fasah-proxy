# Copy to `.env` on the machine (local or dev server). Do not commit `.env`.

# HTTP port for this instance (default in code is 3001). Use a dedicated port on the dev server, e.g. 3100.
PORT=3100

# Default: no auth (matches docker-compose.yml when MONGO_INITDB_* are unset).
MONGO_URI=mongodb://127.0.0.1:27017/fasah-proxy
# If you enable root user on first Mongo init, set these in `.env` then recreate the volume once:
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=your_password
# MONGO_URI=mongodb://admin:your_password@127.0.0.1:27017/fasah-proxy?authSource=admin
FASAH_LAND_SCHEDULE_MAX_MS=900000
FASAH_TEST_TOKEN=
FASAH_USE_PROXY=true
# Per poll tick: max wait for getLandSchedule (default 20000). Prevents one dead proxy from looking like "poll stopped".
FASAH_POLL_REQUEST_TIMEOUT_MS=20000

# Redis (Socket.IO schedule:appointments:save). Default matches docker-compose redis service.
REDIS_URL=redis://127.0.0.1:6379
