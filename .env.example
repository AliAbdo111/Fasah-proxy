# Server
PORT=3001
NODE_ENV=development

# Database (required)
MONGO_URI=mongodb://127.0.0.1:27017/fasah

# Auth (required in production — do not use defaults)
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# FASAH upstream
FASAH_USE_PROXY=true
FASAH_BROKER_BASE_URL=https://fasah.zatca.gov.sa
FASAH_TRANSPORTER_BASE_URL=https://oga.fasah.sa
# Optional: token for schedule cron (otherwise a built-in fallback is used)
# FASAH_TOKEN=

# Booking limits (defaults shown)
# MAX_BOOKINGS_PER_DAY=50
# MAX_BOOKINGS_PER_MONTH=1000
# MAX_TRANSIT_BOOKINGS_PER_DAY=50
# MAX_IMPORT_BOOKINGS_PER_DAY=50
# BOOKING_DAY_TIMEZONE=Africa/Cairo
# BOOKING_DAILY_RESET_ENABLED=true

# Appointment watcher (active window: 13:55–14:30 Africa/Cairo)
WATCHER_ENABLED=true
WATCHER_CRON_TZ=Africa/Cairo
WATCHER_POLL_INTERVAL_MS=3000
WATCHER_REQUEST_TIMEOUT_MS=15000
WATCHER_IGNORE_WINDOW=false
WATCHER_KEEP_POLLING=true
WATCHER_DEFAULT_DEPARTURE=AGF
# Used when polling FASAH land schedule API (SPECIAL is correct for most queue bookings)
WATCHER_SCHEDULE_QUERY_TYPE=SPECIAL
MAX_BOOKING_ATTEMPTS=3

# Seed scripts (optional)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_USERNAME=admin
# SEED_PACKAGE_PASSWORD=ChangeMe123!
